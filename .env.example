APP_NAME="The Modern Ladder API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=themodernladder
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=public

AUTH_GUARD=api

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

API_VERSION=v1
API_PER_PAGE=15
API_MAX_PER_PAGE=50
API_RATE_LIMIT_PER_MINUTE=60
API_THROTTLE_REDIS=true

AI_DRIVER=openai
AI_EXPLANATION_PROVIDER=openai
AI_EXPLANATION_TIMEOUT=15
AI_EXPLANATION_RETRY_TIMES=1
AI_EXPLANATION_RETRY_SLEEP_MS=250
AI_EXPLANATION_FALLBACK_ENABLED=true
AI_EXPLANATION_CACHE_ENABLED=false
AI_EXPLANATION_CACHE_TTL_SECONDS=300
AI_EXPLANATION_PROMPT_VERSION=recipe_template_explanation.v1
AI_EXPLANATION_SCHEMA_VERSION=recipe_template_explanation.v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EXPLANATION_MODEL=gpt-5-mini
OPENAI_STORE=false

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
