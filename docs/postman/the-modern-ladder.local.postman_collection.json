        {
          "name": "Update Preferences",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dietary_patterns\": [\"vegetarian\", \"halal\"],\n  \"preferred_cuisines\": [\"Levantine\", \"Japanese\"],\n  \"disliked_ingredients\": [\"anchovy\", \"olives\"],\n  \"measurement_system\": \"imperial\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/me/preferences",
            "description": "Updates the authenticated user's food preferences."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ingredients",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Search Ingredients",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length > 0) {",
                  "  if (json.data[0].id) pm.collectionVariables.set(\"ingredient_id\", json.data[0].id);",
                  "  if (json.data[0].slug) pm.collectionVariables.set(\"ingredient_slug\", json.data[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/ingredients/search?q={{ingredient_search}}&limit=10",
            "description": "Authenticated ingredient lookup for pantry entry. Saves the first result id and slug."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pantry",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "List Pantry Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length > 0 && json.data[0].id) {",
                  "  pm.collectionVariables.set(\"pantry_item_id\", json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/me/pantry?per_page={{per_page}}",
            "description": "Lists the authenticated user's active pantry items."
          },
          "response": []
        },
        {
          "name": "Add Pantry Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.pantry_item && json.pantry_item.id) pm.collectionVariables.set(\"pantry_item_id\", json.pantry_item.id);",
                  "if (json && json.pantry_item && json.pantry_item.ingredient && json.pantry_item.ingredient.id) pm.collectionVariables.set(\"ingredient_id\", json.pantry_item.ingredient.id);",
                  "if (json && json.pantry_item && json.pantry_item.ingredient && json.pantry_item.ingredient.slug) pm.collectionVariables.set(\"ingredient_slug\", json.pantry_item.ingredient.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ingredient_id\": \"{{ingredient_id}}\",\n  \"quantity\": 2.5,\n  \"unit\": \"cups\",\n  \"note\": \"For smoothies\",\n  \"expires_on\": \"2026-04-15\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/me/pantry",
            "description": "Adds an ingredient to pantry. Run ingredient search first so ingredient_id is filled."
          },
          "response": []
        },
        {
          "name": "Update Pantry Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3,\n  \"unit\": \"slices\",\n  \"note\": \"Cut and ready\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/me/pantry/{{pantry_item_id}}",
            "description": "Updates the pantry item saved in pantry_item_id."
          },
          "response": []
        },
        {
          "name": "Delete Pantry Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/me/pantry/{{pantry_item_id}}",
            "description": "Deletes the pantry item saved in pantry_item_id."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Recipes",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Generate Suggestions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"drink\",\n  \"limit\": 5,\n  \"include_substitutions\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/me/suggestions",
            "description": "Generates pantry-aware recipe suggestions for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Recipe Template Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.template && json.template.id) pm.collectionVariables.set(\"recipe_template_id\", json.template.id);",
                  "if (json && json.template && json.template.slug) pm.collectionVariables.set(\"recipe_template_slug\", json.template.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/recipes/templates/{{recipe_template_id}}",
            "description": "Authenticated recipe detail endpoint. Run the public recipe template list first so recipe_template_id is populated."
          },
          "response": []
        },
        {
          "name": "Recipe Template Explanation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/recipes/templates/{{recipe_template_id}}/explanation",
            "description": "Generates a grounded explanation for the saved recipe_template_id."
          },
          "response": []
        }
      ]
    }
  ]
}
