              "raw": "{\n  \"display_name\": \"Updated Name\",\n  \"bio\": \"Home cook and curious eater.\",\n  \"locale\": \"en-GB\",\n  \"timezone\": \"Europe/London\",\n  \"country_code\": \"GB\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/me/profile",
            "description": "Updates the authenticated profile."
          },
          "response": []
